{
  "version": "2026-04-25",
  "scope": "WeChat-style dyadic chat-record relationship analysis",
  "evidence_levels": {
    "A_direct_chat_evidence": "directly about chat, messaging, CMC, WeChat, email, text, or online dialogue",
    "B_transferable_conversation_evidence": "conversation transcript or dialogue evidence transferable to chat records",
    "C_relationship_theory_background": "relationship theory used only when A/B evidence is sparse"
  },
  "dimensions": [
    {
      "id": "data_sufficiency",
      "name_zh": "数据充分性",
      "question": "这份聊天记录是否足够支持关系分析？",
      "wechat_fields": [
        "sender",
        "timestamp",
        "type",
        "content",
        "platformMessageId"
      ],
      "features": [
        "message_count",
        "speaker_count",
        "time_span_days",
        "text_message_count",
        "voice_count",
        "image_count",
        "missing_text_ratio"
      ],
      "rag_queries": [
        "chat record data sufficiency",
        "conversation transcript sample size",
        "message count relationship analysis"
      ],
      "preferred_evidence": [
        "A_direct_chat_evidence",
        "B_transferable_conversation_evidence"
      ],
      "output": [
        "sufficiency_score",
        "coverage",
        "main_limits",
        "minimum_next_data_needed"
      ]
    },
    {
      "id": "relationship_context",
      "name_zh": "关系类型与场景",
      "question": "两个人更像哪类关系场景？",
      "wechat_fields": [
        "sender",
        "timestamp",
        "content"
      ],
      "features": [
        "address_terms",
        "topic_domains",
        "role_terms",
        "intimacy_terms",
        "task_terms"
      ],
      "rag_queries": [
        "relationship type chat conversation",
        "dyadic relationship conversation context",
        "interpersonal relationship chat logs"
      ],
      "preferred_evidence": [
        "A_direct_chat_evidence",
        "B_transferable_conversation_evidence",
        "C_relationship_theory_background"
      ],
      "output": [
        "relationship_type_guess",
        "confidence",
        "supporting_markers",
        "alternative_types"
      ]
    },
    {
      "id": "tie_strength",
      "name_zh": "关系强度",
      "question": "这段关系连接强度如何？",
      "wechat_fields": [
        "sender",
        "timestamp",
        "content"
      ],
      "features": [
        "message_frequency",
        "initiation_frequency",
        "reciprocity",
        "conversation_density",
        "shared_topic_recurrence"
      ],
      "rag_queries": [
        "微信 关系强度",
        "tie strength reciprocity frequency",
        "WeChat communication relationship quality"
      ],
      "feature_filter": "tie_strength",
      "preferred_evidence": [
        "A_direct_chat_evidence",
        "B_transferable_conversation_evidence"
      ],
      "output": [
        "tie_strength_score",
        "frequency_evidence",
        "reciprocity_evidence",
        "trajectory"
      ]
    },
    {
      "id": "reciprocity_balance",
      "name_zh": "互惠与投入平衡",
      "question": "两个人的互动投入是否平衡？",
      "wechat_fields": [
        "sender",
        "timestamp",
        "content"
      ],
      "features": [
        "message_share_by_speaker",
        "word_share_by_speaker",
        "initiation_share",
        "reply_share",
        "support_given_vs_received"
      ],
      "rag_queries": [
        "reciprocity interaction balance chat relationship",
        "dyadic reciprocity communication",
        "微信 互惠 信息分享"
      ],
      "feature_filter": "tie_strength",
      "preferred_evidence": [
        "A_direct_chat_evidence",
        "B_transferable_conversation_evidence"
      ],
      "output": [
        "balance_score",
        "dominant_speaker",
        "underresponsive_speaker",
        "asymmetry_notes"
      ]
    },
    {
      "id": "response_dynamics",
      "name_zh": "回复节奏与可获得性",
      "question": "两个人在时间上是否能接住对方？",
      "wechat_fields": [
        "sender",
        "timestamp",
        "platformMessageId"
      ],
      "features": [
        "median_response_latency",
        "late_reply_rate",
        "same_day_reply_rate",
        "silence_gaps",
        "turn_taking_balance"
      ],
      "rag_queries": [
        "回复速度 轮次",
        "response latency turn-taking",
        "NaturalTurn conversational turns"
      ],
      "feature_filter": "response_dynamics",
      "preferred_evidence": [
